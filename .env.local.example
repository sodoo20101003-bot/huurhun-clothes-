# === Supabase ===
# Supabase project дотроос: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# Зөвхөн серверт ашиглана (admin үйлдэл). ХЭЗЭЭ Ч клиент талд бүү ил гарга!
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# === Site ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === QPay (https://merchant.qpay.mn-аас авна) ===
QPAY_USERNAME=your_qpay_username
QPAY_PASSWORD=your_qpay_password
QPAY_INVOICE_CODE=YOUR_INVOICE_CODE
QPAY_BASE_URL=https://merchant.qpay.mn/v2
